# =====================================================
# LLM 공급자 선택 (mistral / openai / anthropic 중 하나)
# =====================================================
LLM_PROVIDER=mistral

# =====================================================
# 미스트랄 (기본 권장 - 가성비 좋음)
# =====================================================
MISTRAL_API_KEY=
# 생성 LLM (답변 생성용)
GEN_LLM_MODEL=mistral-small-latest
# 평가 LLM (RAGAS 평가용)
EVAL_LLM_MODEL=mistral-large-latest

# =====================================================
# 오픈AI (선택 - LLM_PROVIDER=openai 일 때만)
# =====================================================
OPENAI_API_KEY=
# 오픈AI 사용 시 모델 예시
# GEN_LLM_MODEL=gpt-4o-mini
# EVAL_LLM_MODEL=gpt-4o

# =====================================================
# 앤트로픽 (선택)
# =====================================================
ANTHROPIC_API_KEY=

# =====================================================
# 코히어 (Reranker 대안 - 선택)
# =====================================================
COHERE_API_KEY=

# =====================================================
# 로컬 모델 (무료, 첫 실행 시 자동 다운로드)
# =====================================================
EMBEDDING_MODEL=BAAI/bge-m3
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# =====================================================
# Qdrant 벡터 DB
# =====================================================
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# =====================================================
# 로그 레벨
# =====================================================
LOG_LEVEL=INFO
